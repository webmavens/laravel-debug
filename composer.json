{
    "name": "webmavens/debug-monitor",
    "description": "Laravel debug / data rule monitoring package",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.0",
        "illuminate/console": ">=8.0 <14.0",
        "illuminate/database": ">=8.0 <14.0",
        "illuminate/http": ">=8.0 <14.0",
        "illuminate/notifications": ">=8.0 <14.0",
        "illuminate/routing": ">=8.0 <14.0",
        "illuminate/support": ">=8.0 <14.0",
        "illuminate/view": ">=8.0 <14.0"
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Webmavens\\DebugMonitor\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Webmavens\\DebugMonitor\\DebugMonitorServiceProvider"
            ]
        }
    },
    "authors": [
        {
            "name": "webmavens",
            "email": "info@webmavens.com"
        }
    ],
    "prefer-stable": true
}
